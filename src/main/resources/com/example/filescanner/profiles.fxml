<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.filescanner.GUI.Controllers.ProfileController"
            style="-fx-background-color: #1e1e2e;"
            prefWidth="1100" prefHeight="700">

    <!-- LEFT SIDE: PROFILE LISTS -->
    <left>
        <VBox spacing="20" style="-fx-padding: 20;">

            <Label text="Profiles"
                   style="-fx-font-size: 24px; -fx-text-fill: #cdd6f4;"/>

            <!-- ACTIVE PROFILES -->
            <Label text="Active Profiles"
                   style="-fx-font-size: 16px; -fx-text-fill: #cdd6f4;"/>

            <TableView fx:id="tblProfiles"
                       style="-fx-background-color: #313244; -fx-border-color: #45475a;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colName" text="Name" prefWidth="180"/>
                </columns>
            </TableView>

            <!-- DELETED PROFILES -->
            <Label text="Deleted Profiles"
                   style="-fx-font-size: 16px; -fx-text-fill: #cdd6f4;"/>

            <TableView fx:id="tblDeletedProfiles"
                       style="-fx-background-color: #313244; -fx-border-color: #45475a;">
                <columns>
                    <TableColumn fx:id="colDeletedId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colDeletedName" text="Name" prefWidth="180"/>
                </columns>
            </TableView>

        </VBox>
    </left>

    <!-- CENTER: EDITOR -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <HBox alignment="CENTER_LEFT">
                <Button text="Dashboard" onAction="#onBack"
                        style="-fx-background-color: #313244; -fx-text-fill: #89b4fa;
                               -fx-font-weight: bold; -fx-padding: 8 15;
                               -fx-background-radius: 8; -fx-border-color: #89b4fa;"/>
            </HBox>

            <Label text="Edit Profile"
                   style="-fx-font-size: 20px; -fx-text-fill: #cdd6f4;"/>

            <!-- NAME -->
            <Label text="Name" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtName"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>

            <!-- ROTATION -->
            <Label text="Rotation" style="-fx-text-fill: #cdd6f4;"/>
            <HBox spacing="10">
                <Slider fx:id="sliderRotation" min="0" max="360" showTickLabels="true" showTickMarks="true"
                        style="-fx-background-color: #313244;" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtRotationValue" prefWidth="60"
                           style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>
            </HBox>

            <!-- BRIGHTNESS -->
            <Label text="Brightness" style="-fx-text-fill: #cdd6f4;"/>
            <HBox spacing="10">
                <Slider fx:id="sliderBrightness" min="-255" max="255"
                        style="-fx-background-color: #313244;" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtBrightnessValue" prefWidth="60"
                           style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>
            </HBox>

            <!-- CONTRAST -->
            <Label text="Contrast" style="-fx-text-fill: #cdd6f4;"/>
            <HBox spacing="10">
                <Slider fx:id="sliderContrast" min="0.1" max="100"
                        style="-fx-background-color: #313244;" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtContrastValue" prefWidth="60"
                           style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>
            </HBox>

            <!-- CHECKBOXES -->
            <HBox spacing="20">
                <CheckBox fx:id="chkSplitOnBarcode" text="Split on barcode"
                          style="-fx-text-fill: #cdd6f4;"/>
                <CheckBox fx:id="chkAutoCrop" text="Auto crop"
                          style="-fx-text-fill: #cdd6f4;"/>
            </HBox>

            <!-- EXPORT FORMAT -->
            <Label text="Export Format" style="-fx-text-fill: #cdd6f4;"/>
            <ComboBox fx:id="comboFormat"
                      style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>

            <!-- BUTTONS -->
            <HBox spacing="10">
                <Button text="Create" onAction="#createProfile"
                        style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;"/>
                <Button text="Save" onAction="#saveProfile"
                        style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e;"/>
                <Button text="Delete" onAction="#deleteProfile"
                        style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e;"/>
            </HBox>

        </VBox>
    </center>

    <!-- RIGHT: PREVIEW -->
    <right>
        <VBox spacing="15" alignment="TOP_CENTER" style="-fx-padding: 20;">

            <Label text="Preview"
                   style="-fx-font-size: 18px; -fx-text-fill: #cdd6f4;"/>

            <ImageView fx:id="imgPreview"
                       fitWidth="350" fitHeight="500"
                       preserveRatio="true"
                       style="-fx-background-color: #121212;"/>

            <Button fx:id="btnLoadSample"
                    text="Load sample image"
                    onAction="#loadSampleImage"
                    style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;"/>

        </VBox>
    </right>

</BorderPane>
