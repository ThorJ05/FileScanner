<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.filescanner.GUI.Controllers.ProfileController"
            style="-fx-background-color: #1e1e2e;"
            prefWidth="900" prefHeight="600">

    <!-- LEFT: Table -->
    <left>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label text="Profiler"
                   style="-fx-font-size: 20px; -fx-text-fill: #cdd6f4;"/>

            <TableView fx:id="profileTable"
                       style="-fx-background-color: #313244; -fx-border-color: #45475a;">
                <columns>
                    <TableColumn fx:id="colName" text="Navn" prefWidth="120"/>
                    <TableColumn fx:id="colRotation" text="Rotation" prefWidth="80"/>
                    <TableColumn fx:id="colFormat" text="Format" prefWidth="80"/>
                    <TableColumn fx:id="colBrightness" text="Brightness" prefWidth="100"/>
                    <TableColumn fx:id="colContrast" text="Contrast" prefWidth="100"/>
                    <TableColumn fx:id="colSplit" text="Split" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </left>

    <!-- CENTER: Editor -->
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <Label text="Rediger profil"
                   style="-fx-font-size: 18px; -fx-text-fill: #cdd6f4;"/>

            <Label text="Navn" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="txtName"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>

            <Label text="Rotation" style="-fx-text-fill: #cdd6f4;"/>
            <Slider fx:id="sliderRotation"
                    min="0" max="270"
                    majorTickUnit="90"
                    blockIncrement="90"
                    snapToTicks="true"
                    showTickLabels="true"
                    showTickMarks="true"/>

            <Label text="Brightness" style="-fx-text-fill: #cdd6f4;"/>
            <Slider fx:id="sliderBrightness" min="-255" max="255"/>

            <Label text="Contrast" style="-fx-text-fill: #cdd6f4;"/>
            <Slider fx:id="sliderContrast" min="0.1" max="10"/>

            <CheckBox fx:id="chkSplit" text="Split on barcode"
                      style="-fx-text-fill: #cdd6f4;"/>

            <Label text="Export format" style="-fx-text-fill: #cdd6f4;"/>
            <ComboBox fx:id="comboFormat"
                      style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>

            <HBox spacing="10">
                <Button text="Opret" onAction="#createProfile"
                        style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;"/>
                <Button text="Gem" onAction="#saveProfile"
                        style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e;"/>
                <Button text="Slet" onAction="#deleteProfile"
                        style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e;"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
