<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.filescanner.GUI.Controllers.UserDashboardController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #1e1e2e;">

    <!-- LEFT MENU -->
    <left>
        <VBox spacing="4" prefWidth="200"
              style="-fx-background-color: #181825; -fx-padding: 20;">
            <Label text="FileScanner"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: #cdd6f4; -fx-padding: 0 0 20 0;"/>

            <Button text="Dashboard" maxWidth="Infinity" onAction="#onDashboard"
                    style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                           -fx-alignment: center-left; -fx-padding: 10;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout" maxWidth="Infinity" onAction="#onLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #f38ba8;
                           -fx-alignment: center-left; -fx-padding: 10;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <HBox spacing="30" style="-fx-padding: 32;">

            <!-- LEFT SIDE: YOUR ORIGINAL DASHBOARD -->
            <VBox spacing="20">
                <Label fx:id="welcomeLabel" text="Welcome back!"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>
                <Label text="Overview of your scanning activity"
                       style="-fx-font-size: 13px; -fx-text-fill: #a6adc8;"/>

                <HBox spacing="16">
                    <VBox style="-fx-background-color: #313244; -fx-padding: 20;
                                 -fx-background-radius: 8;" prefWidth="180">
                        <Label text="Documents Today"
                               style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                        <Label fx:id="docCountLabel" text="0"
                               style="-fx-text-fill: #cdd6f4; -fx-font-size: 28px;
                                      -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox style="-fx-background-color: #313244; -fx-padding: 20;
                                 -fx-background-radius: 8;" prefWidth="180">
                        <Label text="Files Scanned"
                               style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                        <Label fx:id="fileCountLabel" text="0"
                               style="-fx-text-fill: #cdd6f4; -fx-font-size: 28px;
                                      -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox style="-fx-background-color: #313244; -fx-padding: 20;
                                 -fx-background-radius: 8;" prefWidth="180">
                        <Label text="Active Profile"
                               style="-fx-text-fill: #a6adc8; -fx-font-size: 12px;"/>
                        <Label fx:id="activeProfileLabel" text="None"
                               style="-fx-text-fill: #89b4fa; -fx-font-size: 18px;
                                      -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- RIGHT SIDE: SCANNING UI -->
            <VBox spacing="10" alignment="TOP_LEFT">

                <HBox spacing="10">
                    <Button text="Scan" onAction="#onScan"/>
                    <Button text="Reset" onAction="#onReset"/>
                </HBox>

                <Label fx:id="statusLabel" text="Ready to scan..."
                       style="-fx-text-fill: #cdd6f4;"/>

                <Label fx:id="sessionCountLabel" text="Scanned this session: 0"
                       style="-fx-text-fill: #cdd6f4;"/>

                <HBox spacing="20">

                    <ListView fx:id="fileListView"
                              prefWidth="200" prefHeight="300"
                              style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>

                    <ImageView fx:id="imagePreview"
                               fitWidth="350"
                               fitHeight="350"
                               preserveRatio="true"
                               style="-fx-border-color: #cdd6f4;"/>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
