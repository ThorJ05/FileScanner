<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.filescanner.GUI.Controllers.UserDashboardController"
            prefWidth="1100" prefHeight="650"
            style="-fx-background-color: #1e1e2e;">

    <!-- LEFT MENU -->
    <left>
        <VBox spacing="4" prefWidth="200"
              style="-fx-background-color: #181825; -fx-padding: 20;">
            <Label text="FileScanner"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-text-fill: #cdd6f4; -fx-padding: 0 0 20 0;"/>

            <Button text="Dashboard" maxWidth="Infinity" onAction="#onDashboard"
                    style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                           -fx-alignment: center-left; -fx-padding: 10;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout" maxWidth="Infinity" onAction="#onLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #f38ba8;
                           -fx-alignment: center-left; -fx-padding: 10;
                           -fx-background-radius: 6; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20" style="-fx-padding: 32;">

            <!-- DASHBOARD INFO -->
            <VBox spacing="6">
                <Label fx:id="welcomeLabel"
                       text="Welcome back!"
                       style="-fx-text-fill: #cdd6f4; -fx-font-size: 20px; -fx-font-weight: bold;"/>

                <HBox spacing="20">
                    <Label text="Documents:" style="-fx-text-fill: #cdd6f4;"/>
                    <Label fx:id="docCountLabel" text="0" style="-fx-text-fill: #cdd6f4;"/>

                    <Label text="Files:" style="-fx-text-fill: #cdd6f4;"/>
                    <Label fx:id="fileCountLabel" text="0" style="-fx-text-fill: #cdd6f4;"/>

                    <Label text="Active Profile:" style="-fx-text-fill: #cdd6f4;"/>
                    <Label fx:id="activeProfileLabel" text="None" style="-fx-text-fill: #cdd6f4;"/>
                </HBox>
            </VBox>

            <!-- SCAN BUTTONS + STATUS -->
            <HBox spacing="10">
                <Button text="Scan" onAction="#onScan"/>
                <Button text="New box" onAction="#onReset"/>
            </HBox>

            <Label fx:id="statusLabel" text="Ready to scan..."
                   style="-fx-text-fill: #cdd6f4;"/>

            <Label fx:id="sessionCountLabel" text="Scanned this session: 0"
                   style="-fx-text-fill: #cdd6f4;"/>

            <!-- DOCUMENT + PAGE + PREVIEW -->
            <HBox spacing="30">
                <TableView fx:id="pageTable">
                    <columns>
                        <TableColumn fx:id="colReferenceId" text="Ref ID" prefWidth="80"/>
                        <TableColumn fx:id="colLabel" text="Label" prefWidth="120"/>
                        <TableColumn fx:id="colBarcode" text="Barcode" prefWidth="120"/>
                    </columns>
                </TableView>

                <!-- DOCUMENT LIST -->
                <VBox spacing="10">
                    <Label text="Documents" style="-fx-text-fill: #cdd6f4; -fx-font-size: 16px;"/>
                    <ListView fx:id="documentListView" prefWidth="150" prefHeight="400"/>
                </VBox>
                <HBox spacing="10">
                    <Button text="Move Up" onAction="#onMovePageUp"/>
                    <Button text="Move Down" onAction="#onMovePageDown"/>
                </HBox>

                <!-- PAGE LIST -->
                <VBox spacing="10">
                    <Label text="Pages" style="-fx-text-fill: #cdd6f4; -fx-font-size: 16px;"/>
                    <ListView fx:id="pageListView" prefWidth="150" prefHeight="400"/>
                </VBox>

                <!-- IMAGE PREVIEW -->
                <VBox spacing="10">
                    <Label text="Preview" style="-fx-text-fill: #cdd6f4; -fx-font-size: 16px;"/>
                    <ImageView fx:id="imagePreview"
                               fitWidth="450"
                               fitHeight="450"
                               preserveRatio="true"
                               style="-fx-border-color: #cdd6f4;"/>
                </VBox>

            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Rotation:" style="-fx-text-fill: #cdd6f4;"/>

                <Slider fx:id="rotationSlider"
                        min="0" max="360"
                        value="0"
                        blockIncrement="1"
                        showTickLabels="true"
                        showTickMarks="true"
                        majorTickUnit="90"
                        minorTickCount="5"
                        style="-fx-padding: 10;"/>

                <TextField fx:id="rotationField"
                           promptText="0–360"
                           prefWidth="60"
                           style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;"/>
            </HBox>


        </VBox>
    </center>

</BorderPane>
